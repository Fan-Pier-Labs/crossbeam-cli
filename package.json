{
  "name": "crossbeam-cli",
  "version": "0.1.1",
  "description": "CLI and Node.js client for the Crossbeam internal API. Log in with your Crossbeam credentials and read partners, populations, overlaps, reports, and more.",
  "keywords": [
    "crossbeam",
    "cli",
    "partner",
    "ecosystem",
    "account-mapping",
    "api"
  ],
  "license": "BSD-4-Clause",
  "author": {
    "name": "Ryan Hughes",
    "email": "ryan@fanpierlabs.com"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Fan-Pier-Labs/crossbeam-cli.git"
  },
  "homepage": "https://github.com/Fan-Pier-Labs/crossbeam-cli#readme",
  "bugs": {
    "url": "https://github.com/Fan-Pier-Labs/crossbeam-cli/issues"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "bin": {
    "crossbeam": "./dist/cli.js",
    "crossbeam-mcp": "./dist/mcp.js"
  },
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE",
    "NOTICE",
    "ATTRIBUTION.md"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json && chmod +x dist/cli.js dist/mcp.js",
    "prepare": "npm run build",
    "prepublishOnly": "npm run build",
    "clean": "rm -rf dist build *.mcpb",
    "start": "node dist/cli.js",
    "mcp": "node dist/mcp.js",
    "dev": "tsc -p tsconfig.json --watch",
    "bundle:mcpb": "node scripts/build-mcpb.mjs",
    "pack:mcpb": "npm run bundle:mcpb && mcpb pack build/mcpb crossbeam.mcpb"
  },
  "devDependencies": {
    "@anthropic-ai/mcpb": "^2.1.2",
    "@types/node": "^20.0.0",
    "esbuild": "^0.28.1",
    "typescript": "^5.4.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "posthog-node": "^5.38.6",
    "zod": "^4.4.3"
  }
}
